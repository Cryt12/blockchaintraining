# RREPS — environment template. Copy to .env and fill in real values.
# .env is gitignored; never commit real secrets.

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Publishable (anon / public) key — safe to expose to the browser.
SUPABASE_PUBLISHABLE_KEY=

# SECRET / service-role key — backend only. Bypasses Row-Level Security.
# Never expose to the frontend or commit to git.
SUPABASE_SECRET_KEY=

# Legacy JWT signing secret — backend only. Used to verify/sign auth tokens.
SUPABASE_JWT_SECRET=

# Direct Postgres connection string (Project Settings > Database > URI).
# Used to run the SQL migrations in database/migrations.
SUPABASE_DB_URL=

# ---------------------------------------------------------------------------
# Frontend (Vite) — only VITE_-prefixed vars reach the browser bundle.
# Use ONLY the publishable key here, never the secret key.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# Blockchain (Ethereum Sepolia testnet)
# ---------------------------------------------------------------------------
VITE_CONTRACT_ADDRESS=
VITE_SEPOLIA_RPC_URL=
VITE_SEPOLIA_CHAIN_ID=11155111

# ---------------------------------------------------------------------------
# Backend API (Laravel) — set once the backend phase begins.
# ---------------------------------------------------------------------------
JWT_SECRET=
API_BASE_URL=http://localhost:8000
